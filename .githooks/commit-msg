#!/bin/sh
# Remove Co-authored-by (and similar) trailer lines that mention Cursor, so trailers stay tool-neutral.
# Enable once: git config core.hooksPath .githooks

msg="$1"
[ -n "$msg" ] && [ -f "$msg" ] || exit 0
tmp="${msg}.hook.$$"
# Drop co-authored-by lines containing "cursor" (case-insensitive)
grep -viE '^co-authored-by:.*cursor' "$msg" > "$tmp" 2>/dev/null || cp "$msg" "$tmp"
mv "$tmp" "$msg"
# Drop Made-with: trailers (some environments inject tool attribution)
grep -viE '^made-with:' "$msg" > "$tmp" 2>/dev/null || cp "$msg" "$tmp"
mv "$tmp" "$msg"
exit 0
